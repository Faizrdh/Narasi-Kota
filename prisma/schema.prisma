generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  REDAKSI
  EDITOR
  REPORTER
  USER
}

enum WorkflowStatus {
  IDE
  PENUGASAN
  MENULIS
  REVIEW
  REVISI
  SIAP_PUBLISH
  PUBLISHED
}

enum Priority {
  TINGGI
  SEDANG
  RENDAH
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(USER)
  image     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions             Session[]
  refreshTokens        RefreshToken[]
  passwordResetTokens  PasswordResetToken[]   // ← TAMBAHAN
  articles             Article[]
  reporterWorkflows    ArticleWorkflow[] @relation("reporter")
  editorWorkflows      ArticleWorkflow[] @relation("editor")
  activityLogs         ActivityLog[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ── MODEL BARU untuk Forgot Password OTP ──────────────────────
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @db.Text   // Disimpan sebagai SHA-256 hash
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model Article {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  body        String
  excerpt     String?
  image       String?
  detailImage String?
  detailVideo String?
  category    String
  status      String    @default("draft")
  views       Int       @default(0)
  likes       Int       @default(0)
  authorId    String
  publishedAt DateTime?
  scheduledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author      User                @relation(fields: [authorId], references: [id])
  pageViews   PageView[]
  impressions ArticleImpression[]
  ArticleLike ArticleLike[]

  @@index([status, scheduledAt])
  @@map("articles")
}

model PageView {
  id          String   @id @default(cuid())
  articleId   String
  visitorId   String
  timeSpent   Int      @default(0)
  scrollDepth Int      @default(0)
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([visitorId])
  @@index([createdAt])
  @@map("page_views")
}

model ArticleImpression {
  id        String   @id @default(cuid())
  articleId String
  visitorId String?
  createdAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, visitorId])
  @@index([articleId])
  @@index([createdAt])
  @@map("article_impressions")
}

model ArticleLike {
  id        String   @id @default(cuid())
  articleId String
  visitorId String
  createdAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, visitorId])
  @@index([articleId])
  @@index([visitorId])
  @@map("article_likes")
}

model ArticleWorkflow {
  id             String         @id @default(cuid())
  judulBerita    String
  kategori       String
  subKategori    String?
  workflowStatus WorkflowStatus @default(IDE)
  priority       Priority       @default(SEDANG)
  deadline       DateTime?
  reporterId     String?
  editorId       String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  reporter     User?         @relation("reporter", fields: [reporterId], references: [id])
  editor       User?         @relation("editor", fields: [editorId], references: [id])
  activityLogs ActivityLog[]

  @@map("article_workflows")
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  actorName  String
  actorId    String?
  workflowId String
  createdAt  DateTime @default(now())

  actor    User?           @relation(fields: [actorId], references: [id])
  workflow ArticleWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

model ContributorApplication {
  id             String   @id @default(cuid())
  namaLengkap    String
  nomorHP        String
  email          String
  tanggalLahir   DateTime
  jenisKelamin   String?
  role           String
  pengalaman     String
  spesialisasi   String
  motivasi       String
  portofolioLink String?
  cvFileUrl      String?
  status         String   @default("pending")
  catatanAdmin   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("contributor_applications")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  color       String   @default("zinc")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("categories")
}